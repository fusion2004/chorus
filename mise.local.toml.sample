# Copy this file to mise.local.toml and fill in the blanks.
# mise.local.toml is gitignored. mise auto-loads it when you `cd`
# into the repo (assuming `mise activate` is in your shell rc).

[env]
# Secrets
AWS_ACCESS_KEY_ID = ""
AWS_SECRET_ACCESS_KEY = ""
HUBOT_DISCORD_TOKEN = ""
HUBOT_STREAM_SOURCE_PASSWORD = ""

# Per-deployment Discord IDs (not secret, but specific to your guild)
DEBUG_CHANNEL_ID = ""
GUILD_ID = ""
